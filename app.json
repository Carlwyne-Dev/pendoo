{
  "expo": {
    "name": "Pendoo",
    "slug": "pendoo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pics/favicon_new.png",
    "scheme": "pendoomobile",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/pics/favicon_new.png",
      "bundleIdentifier": "com.pendoo.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.pendoo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pics/favicon_new.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },

    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/pics/onboarding_pendoo.png",
          "imageWidth": 200
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9538e8d4-c2c8-4fd5-bc33-6ce426405e5f"
      }
    },
    "owner": "wananana"
  }
}
